<%- include("header.ejs") %>

<section id="create-review">
  <div class="form-card">
    <h1 class="form-title">Unleash Your Inner Storyteller</h1>

    <form action="/submit" method="POST" class="form-create">
      <div class="form-group">
        <label for="book-name" class="form-label">Book Title</label>
        <input type="text" id="book-name" name="book-name" class="form-input" placeholder="Enter book title..." required autocomplete="off">
      </div>

      <div class="form-group">
        <label for="isbn" class="form-label">Book Cover Code (ISBN or OLID)</label>
        <input type="text" id="isbn" name="isbn" class="form-input" placeholder="e.g. 9780451524935 or OL26322951M" autocomplete="off">
        <span class="form-help">Tip: Use an ISBN (e.g. 978...) or an OpenLibrary ID (e.g. OL...) to fetch the cover art automatically.</span>
      </div>

      <div class="form-group">
        <label for="body-review" class="form-label">Your Review</label>
        <textarea id="body-review" name="body-review" class="form-textarea" placeholder="Share your thoughts about this book..." required autocomplete="off"></textarea>
      </div>

      <div class="form-group">
        <label class="form-label">Rating</label>
        <div class="star-rating-select">
          <input type="radio" id="star5" name="rating" value="5" checked /><label for="star5" title="5 stars">★</label>
          <input type="radio" id="star4" name="rating" value="4" /><label for="star4" title="4 stars">★</label>
          <input type="radio" id="star3" name="rating" value="3" /><label for="star3" title="3 stars">★</label>
          <input type="radio" id="star2" name="rating" value="2" /><label for="star2" title="2 stars">★</label>
          <input type="radio" id="star1" name="rating" value="1" /><label for="star1" title="1 star">★</label>
        </div>
      </div>

      <div class="form-group">
        <label for="author-name" class="form-label">Reviewer Name</label>
        <input type="text" id="author-name" name="author-name" class="form-input" placeholder="Enter your name..." required autocomplete="off"> 
      </div>

      <button type="submit" name="SUBMIT" class="submit-btn w-100 mt-3">Submit Review</button>
    </form>
  </div>
</section>

<%- include("footer.ejs") %>